{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "prune-catalog",
            "type": "debugpy",
            "request": "launch",
            "module": "rpg_librarian",
            "console": "integratedTerminal",
            "args": [
                "prune-catalog",
                "c:\\rpg",
            ]
        },
        {
            "name": "extract-errors",
            "type": "debugpy",
            "request": "launch",
            "module": "rpg_librarian",
            "console": "integratedTerminal",
            "args": [
                "extract-errors",
                "c:\\rpg",
            ]
        },
        {
            "name": "report-duplicates",
            "type": "debugpy",
            "request": "launch",
            "module": "rpg_librarian",
            "console": "integratedTerminal",
            "args": [
                "report-duplicates",
                "c:\\rpg",
            ]
        },
        {
            "name": "delete-duplicates",
            "type": "debugpy",
            "request": "launch",
            "module": "rpg_librarian",
            "console": "integratedTerminal",
            "args": [
                "delete-duplicates",
                "c:\\rpg",
            ]
        },
        {
            "name": "build",
            "type": "debugpy",
            "request": "launch",
            "module": "rpg_librarian",
            "console": "integratedTerminal",
            "args": [
                "build-catalog",
                "c:\\rpg",
            ]
        },
        {
            "name": "clean",
            "type": "debugpy",
            "request": "launch",
            "module": "rpg_librarian",
            "console": "integratedTerminal",
            "args": [
                "clean",
                "c:\\rpg",
            ]
        },
        {
            "name": "test",
            "type": "debugpy",
            "request": "launch",
            "module": "rpg_librarian",
            "console": "integratedTerminal",
            "args": "test"
        },
        {
            "name": "custom args",
            "type": "debugpy",
            "request": "launch",
            "module": "rpg_librarian",
            "console": "integratedTerminal",
            "args": "${command:pickArgs}"
        },
        {
            "name": "Integration Tests",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "justMyCode": true,
            "args": [
                "-s",
                "tests/integration"
            ],
            "console": "integratedTerminal"
        }
    ]
}
